generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DisplayType {
  BUTTON
  LINK
  TILE
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  isAdmin       Boolean  @default(false)
  defaultPageId String?
  lastLogin     DateTime @default(now())
  createdAt     DateTime @default(now())

  defaultPage Page? @relation("UserDefaultPage", fields: [defaultPageId], references: [id], onDelete: SetNull)
}

model Page {
  id     String  @id @default(cuid())
  label  String
  slug   String  @unique
  order  Int     @default(0)
  isHome Boolean @default(false)

  sections    PageSection[]
  itemPages   ItemPage[]
  defaultFor  User[]        @relation("UserDefaultPage")
}

model Section {
  id          String      @id @default(cuid())
  title       String
  displayType DisplayType

  pages PageSection[]
  items Item[]
}

model PageSection {
  pageId        String
  sectionId     String
  order         Int      @default(0)
  titleOverride String?

  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([pageId, sectionId])
}

model Item {
  id          String  @id @default(cuid())
  sectionId   String
  name        String
  href        String
  description String?
  image       String?
  disabled    Boolean @default(false)
  order       Int     @default(0)

  section Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  pages   ItemPage[]
}

model ItemPage {
  itemId String
  pageId String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@id([itemId, pageId])
}
